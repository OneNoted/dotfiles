#!/bin/sh

set -eu

find_real_tv() {
	self_dir=$(
		CDPATH='' cd -- "$(dirname -- "$0")" && pwd -P
	)
	self_path="$self_dir/$(basename -- "$0")"
	old_ifs=$IFS
	IFS=:

	for dir in $PATH; do
		[ -n "$dir" ] || dir=.
		candidate="$dir/tv"
		[ -x "$candidate" ] || continue

		candidate_dir=$(
			CDPATH='' cd -- "$(dirname -- "$candidate")" 2>/dev/null && pwd -P
		) || continue
		candidate_path="$candidate_dir/$(basename -- "$candidate")"

		if [ "$candidate_path" != "$self_path" ]; then
			printf '%s\n' "$candidate"
			IFS=$old_ifs
			return 0
		fi
	done

	IFS=$old_ifs
	return 1
}

real_tv=$(find_real_tv) || {
	printf '%s\n' "tv wrapper: could not find the real tv binary in PATH" >&2
	exit 127
}

if [ "${1-}" = "sesh" ]; then
	shift
	selection=$("$real_tv" sesh-picker "$@") || exit $?

	[ -n "$selection" ] || exit 0
	exec sesh connect "$selection"
fi

exec "$real_tv" "$@"
