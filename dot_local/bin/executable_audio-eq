#!/bin/sh

set -eu

data_home=${XDG_DATA_HOME:-"$HOME/.local/share"}
cache_home=${XDG_CACHE_HOME:-"$HOME/.cache"}
src_dir=$data_home/audio-eq-manager
cache_dir=$cache_home/audio-eq-manager
bin=$cache_dir/audio-eq

needs_build=0
if [ ! -x "$bin" ]; then
	needs_build=1
else
	for src_file in "$src_dir"/*.go "$src_dir"/go.mod "$src_dir"/go.sum; do
		[ -e "$src_file" ] || continue
		if [ "$src_file" -nt "$bin" ]; then
			needs_build=1
			break
		fi
	done
fi

if [ "$needs_build" -eq 1 ]; then
	if ! command -v go >/dev/null 2>&1; then
		printf '%s\n' "audio-eq: go is required to build $src_dir" >&2
		exit 127
	fi
	mkdir -p "$cache_dir"
	(cd "$src_dir" && go build -o "$bin" .)
fi

exec "$bin" "$@"
