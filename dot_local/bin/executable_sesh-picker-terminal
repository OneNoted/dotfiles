#!/bin/sh

set -eu

selection=$(tv sesh-picker "$@") || exit $?

[ -n "$selection" ] || exit 0

if command -v setsid >/dev/null 2>&1; then
	setsid -f kitty -1 -e sesh connect "$selection" >/dev/null 2>&1
else
	nohup kitty -1 -e sesh connect "$selection" >/dev/null 2>&1 &
fi

if [ -n "${KITTY_WINDOW_ID-}" ] && command -v kitty >/dev/null 2>&1; then
	kitty @ close-window --self --no-response >/dev/null 2>&1 || true
fi
