set -q AUDIBLE_PLUGIN_DIR; or set -gx AUDIBLE_PLUGIN_DIR $XDG_DATA_HOME/audible/plugins
set -q PI_CODING_AGENT_DIR; or set -gx PI_CODING_AGENT_DIR $XDG_DATA_HOME/pi/agent
set -q EMACSDIR; or set -gx EMACSDIR $XDG_CONFIG_HOME/emacs
set -q DOOMDIR; or set -gx DOOMDIR $XDG_CONFIG_HOME/doom
set -q DOOMPROFILE; or set -gx DOOMPROFILE default
set -q GTK_USE_PORTAL; or set -gx GTK_USE_PORTAL 1

for dir in $GOPATH (dirname $PYTHON_HISTORY) $ANSIBLE_HOME $PLATFORMIO_CACHE_DIR $npm_config_devdir $CUDA_CACHE_PATH $__GL_SHADER_DISK_CACHE_PATH $FLY_CONFIG_DIR $MITMPROXY_CONF_DIR $AUDIBLE_CONFIG_DIR $AUDIBLE_PLUGIN_DIR $PI_CODING_AGENT_DIR $TF_PLUGIN_CACHE_DIR
    test -d "$dir"; or mkdir -p "$dir"
end

contains -- $NPM_CONFIG_PREFIX/bin $PATH; or set -gx PATH $NPM_CONFIG_PREFIX/bin $PATH
contains -- $BUN_INSTALL/bin $PATH; or set -gx PATH $BUN_INSTALL/bin $PATH
contains -- $CARGO_HOME/bin $PATH; or set -gx PATH $CARGO_HOME/bin $PATH
contains -- $XDG_BIN_HOME $PATH; or set -gx PATH $XDG_BIN_HOME $PATH
contains -- $EMACSDIR/bin $PATH; or set -gx PATH $EMACSDIR/bin $PATH

# Fastfetch Greeting
set fish_greeting

# Shared shell aliases/env vars from chezmoi data
test -f $XDG_CONFIG_HOME/shared/shell-core.fish; and source $XDG_CONFIG_HOME/shared/shell-core.fish

test -f $XDG_CONFIG_HOME/fish/secrets.fish; and source $XDG_CONFIG_HOME/fish/secrets.fish

if status is-interactive
    ##### Inits #####

    # Television
    if command -q tv
        tv init fish | source
    end

    # Starship
    if command -q starship
        starship init fish | source
    end

    # Zoxide
    if command -q zoxide
        zoxide init fish | source
    end

    # Atuin
    if command -q atuin
        atuin init fish --disable-up-arrow | source
    end

    # Carapace
    if command -q carapace
        set -Ux CARAPACE_BRIDGES 'zsh,fish,bash,inshellisense' # optional
        set -gx CARAPACE_EXCLUDES paru
        carapace _carapace | source
    end

    # fzf
    if command -q fzf
        fzf --fish | FZF_CTRL_R_COMMAND= FZF_CTRL_T_COMMAND= source
    end

    #Aliases
    # dc for television fuzzy finding through .config/ files
    alias dc cd
    # fuzzy attach zellij via television
    alias zel 'zellij attach $(zellij ls -s | tv)'
    alias claude 'claude --permission-mode bypassPermissions'
    alias codex 'codex --dangerously-bypass-approvals-and-sandbox'

    # back aliases
    alias .. 'cd ..'
    alias ... 'cd ../..'
    alias .... 'cd ../../..'
    alias ..... 'cd ../../../..'
    alias ...... 'cd ../../../../..'

    # Grep aliases
    alias dir 'dir --color=auto'
    alias vdir 'vdir --color=auto'
    alias grep 'grep --color=auto'
    alias fgrep 'fgrep --color=auto'
    alias egrep 'egrep --color=auto'

    # Yazi Shell Wrapper
    function y
        set tmp (mktemp -t "yazi-cwd.XXXXXX")
        yazi $argv --cwd-file="$tmp"
        if read -z cwd <"$tmp"; and [ -n "$cwd" ]; and [ "$cwd" != "$PWD" ]
            builtin cd -- "$cwd"
        end
        rm -f -- "$tmp"
    end

    # Variables
    set -g fish_key_bindings fish_vi_key_bindings
end
