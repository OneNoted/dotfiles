set -q STARSHIP_CONFIG; or set -gx STARSHIP_CONFIG $XDG_CONFIG_HOME/starship.toml
set -q STARSHIP_CACHE; or set -gx STARSHIP_CACHE $XDG_CACHE_HOME/starship
