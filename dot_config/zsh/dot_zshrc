##################################
##### Zsh configuration file #####
##################################

##### Line Editor #####
bindkey -v
export KEYTIMEOUT=1

#####^Line Editor^#####

##### Zinit Plugin Manager #####
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"

# Source / Load Zinit
source "${ZINIT_HOME}/zinit.zsh"

ZSH_IN_TASKERS=0
[[ ${TASKERS_EMBEDDED:-0} == 1 || ${TERM_PROGRAM:-} == taskers ]] && ZSH_IN_TASKERS=1

# 1. Core Completion 
zinit load zsh-users/zsh-completions

# Load completions before binding editor widgets so later plugins see the
# final completion functions and we don't rely on zinit's deferred scheduler.
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

# 2. Fish Experience Stack 
zinit load olets/zsh-abbr                         
# zinit load "$HOME/Projects/zsh-fishy-deletions/"
zinit load OneNoted/zsh-fishy-deletions

# Keep autosuggestions stable once widgets are bound; rebinding on every
# precmd is unnecessary after we make the load order deterministic.
ZSH_AUTOSUGGEST_MANUAL_REBIND=1


# Use history first, then completion engine as fallback
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

zinit load zsh-users/zsh-history-substring-search
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
if (( ! ZSH_IN_TASKERS )); then
  zinit load zsh-users/zsh-autosuggestions
fi

# Menu selection (arrow keys)
zstyle ':completion:*' menu select

# Fuzzy matching:
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}' 'r:|[._-]=* r:|=*' 'l:|=* r:|=*'

# Grouping and Descriptions
zstyle ':completion:*' group-name ''
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' verbose yes

# Carapace completions (1000+ commands with descriptions)
export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense'
export CARAPACE_EXCLUDES='paru'
if command -v carapace >/dev/null 2>&1; then
  source <(carapace _carapace)
fi

#####^Zinit Plugin Manager^#####



##### Initializations #####

# Starship Prompt
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi
# Atuin command history
if command -v atuin >/dev/null 2>&1; then
  eval "$(atuin init zsh)"
fi
# Television fuzzy finder
if command -v tv >/dev/null 2>&1; then
  eval "$(tv init zsh)"
fi

#####^Initializations^#####

##### Environment Variables #####


# Shared shell aliases/env vars from chezmoi data
if [[ -f "$XDG_CONFIG_HOME/shared/shell-core.zsh" ]]; then
  source "$XDG_CONFIG_HOME/shared/shell-core.zsh"
fi

#####^Environment Variables^#####

##### Aliases #####

# fuzzy attach zellij via television
alias zel='zellij attach $(zellij ls -s | tv)'
alias claude='claude --permission-mode bypassPermissions'
alias codex='codex --dangerously-bypass-approvals-and-sandbox'

# back aliases
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias ......='cd ../../../../..'

# Yazi wrapper that updates cwd on exit.
y() {
  local tmp cwd yazi_status
  tmp="$(mktemp -t yazi-cwd.XXXXXX)" || return 1

  yazi "$@" --cwd-file="$tmp"
  yazi_status=$?

  if [[ -r "$tmp" ]]; then
    cwd="$(<"$tmp")"
    if [[ -n "$cwd" && "$cwd" != "$PWD" ]]; then
      builtin cd -- "$cwd"
    fi
  fi

  rm -f -- "$tmp"
  return $yazi_status
}

#####^Aliases^#####



##### Binds #####
#####^Binds^#####

# Quickshell default config QML import path
export QML_IMPORT_PATH="${QML_IMPORT_PATH:+$QML_IMPORT_PATH:}$XDG_CONFIG_HOME/quickshell/default/lib"


# Zoxide cd history (must be last)
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

# zsh-syntax-highlighting must be sourced after every other widget, keybinding,
# completion, and prompt init so it sees the final editor state.
if (( ! ZSH_IN_TASKERS )); then
  zinit load zsh-users/zsh-syntax-highlighting
fi

