[Unit]
Description=T3 Code headless web UI
Documentation=https://github.com/pingdotgg/t3code
Wants=network-online.target
After=network-online.target tailscaled.service
StartLimitIntervalSec=0

[Service]
Type=simple
WorkingDirectory=%h
ExecStartPre=/usr/bin/systemctl is-active --quiet tailscaled.service
ExecStart=/usr/bin/npm exec --yes --package t3@0.0.28 -- t3 serve --mode web --host 127.0.0.1 --port 3773 --base-dir %h/.local/share/t3code --no-browser --tailscale-serve --tailscale-serve-port 443 %h
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=default.target
