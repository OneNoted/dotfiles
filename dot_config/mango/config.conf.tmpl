# Mango WM Configuration

# Window Effects 
blur=1
blur_layer=0
blur_optimized=1
blur_params_num_passes=3
blur_params_radius=10
blur_params_noise=0.01
blur_params_brightness=1.0
blur_params_contrast=0.89
blur_params_saturation=1.0

shadows=1
layer_shadows=0
shadow_only_floating=0
shadows_size=15
shadows_blur=30
shadows_position_x=0
shadows_position_y=2
shadowscolor=0x00000010

border_radius=9
no_radius_when_single=0
focused_opacity=1.0
unfocused_opacity=0.99

# Animation Configuration
animations=1
layer_animations=1
animation_type_open=slide
animation_type_close=slide
animation_fade_in=1
animation_fade_out=1
tag_animation_direction=1
zoom_initial_ratio=0.3
zoom_end_ratio=0.8
fadein_begin_opacity=0.5
fadeout_begin_opacity=0.8
animation_duration_move=250
animation_duration_open=200
animation_duration_tag=180
animation_duration_close=300
animation_duration_focus=0
animation_curve_open=0.46,1.0,0.29,1
animation_curve_move=0.46,1.0,0.29,1
animation_curve_tag=0.46,1.0,0.29,1
animation_curve_close=0.08,0.92,0,1
animation_curve_focus=0.46,1.0,0.29,1
animation_curve_opafadeout=0.5,0.5,0.5,0.5
animation_curve_opafadein=0.46,1.0,0.29,1

# Scroller Layout Setting
scroller_structs=20
scroller_default_proportion=0.5
scroller_focus_center=0
scroller_prefer_center=0
edge_scroller_pointer_focus=1
scroller_default_proportion_single=1.0
scroller_proportion_preset=0.33,0.5,0.67

# Master-Stack Layout Setting
new_is_master=1
default_mfact=0.5
default_nmaster=1
smartgaps=0

# Overview Setting
hotarea_size=10
enable_hotarea=1
ov_tab_mode=0
overviewgappi=5
overviewgappo=30

# Misc
no_border_when_single=0
axis_bind_apply_timeout=100
focus_on_activate=1
idleinhibit_ignore_visible=0
sloppyfocus=1
warpcursor=1
focus_cross_monitor=0
focus_cross_tag=0
enable_floating_snap=0
snap_distance=30
cursor_size=24
drag_tile_to_tile=1

# Keyboard
repeat_rate=50
repeat_delay=200
numlockon=1
xkb_rules_layout=us

# Trackpad
disable_trackpad=0
tap_to_click=1
tap_and_drag=1
drag_lock=0
trackpad_natural_scrolling=1
disable_while_typing=1
left_handed=0
middle_button_emulation=0
swipe_min_threshold=1

# Mouse
mouse_natural_scrolling=0

# Appearance — gaps match niri (10px uniform)
gappih=10
gappiv=10
gappoh=10
gappov=10
scratchpad_width_ratio=0.8
scratchpad_height_ratio=0.9
borderpx=3
rootcolor=0x1e1e2eff
bordercolor=0x505050ff
focuscolor=0x7fc8ff20
maximizescreencolor=0x89b4fa80
urgentcolor=0x9b0000ff
scratchpadcolor=0x516c93ff
globalcolor=0xb153a7ff
overlaycolor=0x14a57cff

# Tag layouts (default to scroller — closest to niri's column model)
tagrule=id:1,layout_name:scroller
tagrule=id:2,layout_name:scroller
tagrule=id:3,layout_name:scroller
tagrule=id:4,layout_name:scroller
tagrule=id:5,layout_name:scroller
tagrule=id:6,layout_name:scroller
tagrule=id:7,layout_name:scroller
tagrule=id:8,layout_name:scroller
tagrule=id:9,layout_name:scroller

# ─── Key Bindings ────────────────────────────────────────────────
# Modifier mapping: niri Mod = SUPER here

# Reload config
bind=SUPER,r,reload_config

# Program launchers
bind=SUPER,Return,spawn,kitty
bind=SUPER,t,spawn,kitty
bind=SUPER,space,spawn,vicinae toggle
bind=SUPER,e,spawn,kitty -e yazi
bind=SUPER,w,spawn,zen-browser --new-window
bind=SUPER,x,spawn,obsidian
bind=CTRL,Tab,spawn,kitty -e btop

# Close / Quit
bind=SUPER,q,killclient,
bind=SUPER+SHIFT+CTRL,m,quit
bind=CTRL+ALT,Delete,quit

# Focus direction 
bind=SUPER,h,focusdir,left
bind=SUPER,j,focusdir,down
bind=SUPER,k,focusdir,up
bind=SUPER,l,focusdir,right
bind=SUPER,Left,focusdir,left
bind=SUPER,Down,focusdir,down
bind=SUPER,Up,focusdir,up
bind=SUPER,Right,focusdir,right

# Move / swap windows 
bind=SUPER+SHIFT,h,exchange_client,left
bind=SUPER+SHIFT,j,exchange_client,down
bind=SUPER+SHIFT,k,exchange_client,up
bind=SUPER+SHIFT,l,exchange_client,right
bind=SUPER+SHIFT,Left,exchange_client,left
bind=SUPER+SHIFT,Down,exchange_client,down
bind=SUPER+SHIFT,Up,exchange_client,up
bind=SUPER+SHIFT,Right,exchange_client,right

# Monitor focus 
bind=SUPER+CTRL,h,focusmon,left
bind=SUPER+CTRL,j,focusmon,down
bind=SUPER+CTRL,k,focusmon,up
bind=SUPER+CTRL,l,focusmon,right
bind=SUPER+CTRL,Left,focusmon,left
bind=SUPER+CTRL,Down,focusmon,down
bind=SUPER+CTRL,Up,focusmon,up
bind=SUPER+CTRL,Right,focusmon,right

# Move window to monitor 
bind=SUPER+SHIFT+CTRL,h,tagmon,left
bind=SUPER+SHIFT+CTRL,j,tagmon,down
bind=SUPER+SHIFT+CTRL,k,tagmon,up
bind=SUPER+SHIFT+CTRL,l,tagmon,right
bind=SUPER+SHIFT+CTRL,Left,tagmon,left
bind=SUPER+SHIFT+CTRL,Down,tagmon,down
bind=SUPER+SHIFT+CTRL,Up,tagmon,up
bind=SUPER+SHIFT+CTRL,Right,tagmon,right

# Tag navigation 
bind=SUPER,1,view,1,0
bind=SUPER,2,view,2,0
bind=SUPER,3,view,3,0
bind=SUPER,4,view,4,0
bind=SUPER,5,view,5,0
bind=SUPER,6,view,6,0
bind=SUPER,7,view,7,0
bind=SUPER,8,view,8,0
bind=SUPER,9,view,9,0

# Move window to tag 
bind=SUPER+SHIFT,1,tag,1,0
bind=SUPER+SHIFT,2,tag,2,0
bind=SUPER+SHIFT,3,tag,3,0
bind=SUPER+SHIFT,4,tag,4,0
bind=SUPER+SHIFT,5,tag,5,0
bind=SUPER+SHIFT,6,tag,6,0
bind=SUPER+SHIFT,7,tag,7,0
bind=SUPER+SHIFT,8,tag,8,0
bind=SUPER+SHIFT,9,tag,9,0

# Adjacent tag navigation 
bind=SUPER,Page_Down,viewtoright,0
bind=SUPER,Page_Up,viewtoleft,0
bind=SUPER,u,viewtoright,0
bind=SUPER,i,viewtoleft,0
bind=SUPER+CTRL,Page_Down,tagtoright,0
bind=SUPER+CTRL,Page_Up,tagtoleft,0
bind=SUPER+CTRL,u,tagtoright,0
bind=SUPER+CTRL,i,tagtoleft,0

# Window states
bind=SUPER,f,togglefullscreen,
bind=SUPER+SHIFT,f,togglefakefullscreen,
bind=SUPER,v,togglefloating,
bind=SUPER,o,toggleoverview,
bind=SUPER,a,togglemaximizescreen,
bind=SUPER,z,toggle_scratchpad

# Scroller layout 
bind=SUPER+SHIFT,r,switch_proportion_preset,
bind=SUPER,e,set_proportion,1.0

# Switch layout
bind=SUPER,n,switch_layout

# Gaps
bind=SUPER+SHIFT,equal,incgaps,1
bind=SUPER+SHIFT,minus,incgaps,-1

# Move floating windows
bind=CTRL+SHIFT,Up,movewin,+0,-50
bind=CTRL+SHIFT,Down,movewin,+0,+50
bind=CTRL+SHIFT,Left,movewin,-50,+0
bind=CTRL+SHIFT,Right,movewin,+50,+0

# Resize windows
bind=CTRL+ALT,Up,resizewin,+0,-50
bind=CTRL+ALT,Down,resizewin,+0,+50
bind=CTRL+ALT,Left,resizewin,-50,+0
bind=CTRL+ALT,Right,resizewin,+50,+0

# Volume / Brightness / Media 
bind=NONE,XF86AudioRaiseVolume,spawn,wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bind=NONE,XF86AudioLowerVolume,spawn,wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bind=NONE,XF86AudioMute,spawn,wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bind=NONE,XF86AudioMicMute,spawn,wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bind=NONE,XF86MonBrightnessUp,spawn,brightnessctl -e4 -n2 set 5%+
bind=NONE,XF86MonBrightnessDown,spawn,brightnessctl -e4 -n2 set 5%-
bind=NONE,XF86AudioNext,spawn,playerctl next
bind=NONE,XF86AudioPrev,spawn,playerctl previous
bind=NONE,XF86AudioPlay,spawn,playerctl play-pause
bind=NONE,XF86AudioPause,spawn,playerctl play-pause

# Screenshots 
bind=NONE,Print,spawn,sh -c 'grim -g "$(slurp)" - | wl-copy'
bind=CTRL,Print,spawn,sh -c 'grim - | wl-copy'
bind=SUPER+CTRL,s,spawn,sh -c 'grim -g "$(slurp)" - | wl-copy'
bind=SUPER+CTRL+SHIFT,s,spawn,{{ .chezmoi.homeDir }}/.config/niri/region-record-toggle.sh
bind=SUPER+ALT,d,spawn,whispers
bind=SUPER+ALT,v,spawn,whispers voice
bind=SUPER+CTRL,c,spawn,zoop


# Mouse Button Bindings
# mousebind=SUPER,btn_left,moveresize,curmove
# mousebind=SUPER,btn_right,moveresize,curresize

# Axis Bindings (scroll through tags like niri workspace scroll)
axisbind=SUPER,UP,viewtoleft_have_client
axisbind=SUPER,DOWN,viewtoright_have_client

# Startup commands
{{ if eq .chezmoi.hostname "aeolus" -}}
# Output configuration — aeolus
exec-once=wlr-randr --output DP-3 --mode 3440x1440@174.962997 --pos 0,0 --output DP-4 --mode 3440x1440@174.962997 --pos 3440,0 --output DP-5 --mode 5120x1440@239.761002 --pos 6880,0
{{ end -}}
exec-once=vicinae server
exec-once=swww-daemon
exec-once=ashell
